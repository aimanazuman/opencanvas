# OpenCanvas Production Environment Variables
# Copy this file to .env.prod and fill in your values:
#   cp .env.prod.example .env.prod

# Your domain (e.g. opencanvas.example.com)
DOMAIN=opencanvas.example.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# Gmail address for sending emails (verification, password resets, etc.)
SMTP_USER=your-gmail@gmail.com
